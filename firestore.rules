rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Collection: rotas
    // Collection: duties
    // Collection: messages
    // Collection: leaveRequests
    // Collection: swapRequests
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "ragnarkaladin@gmail.com" && request.auth.token.email_verified == true));
    }

    function isCNO() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'cno';
    }

    function isHR() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'hr';
    }

    function isWardAdmin() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ward_admin';
    }

    function isStaff() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'staff';
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin() || isCNO() || isHR() || 
                     (isWardAdmin() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.wardId == resource.data.wardId);
      allow create: if isAdmin();
      allow update: if isAdmin() || (isOwner(userId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'phone', 'isDefaultPassword']));
      allow delete: if isAdmin();
    }

    match /rotas/{rotaId} {
      allow read: if isAuthenticated();
      allow create: if isWardAdmin() || isCNO();
      allow update: if isWardAdmin() || isCNO();
      allow delete: if isCNO();
    }

    match /duties/{dutyId} {
      allow read: if isAuthenticated();
      allow create: if isWardAdmin() || isCNO();
      allow update: if isWardAdmin() || isCNO();
      allow delete: if isWardAdmin() || isCNO();
    }

    match /messages/{messageId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.senderId || request.auth.uid == resource.data.receiverId);
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.senderId;
      allow update: if isAuthenticated() && request.auth.uid == resource.data.receiverId && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow delete: if false;
    }

    match /leaveRequests/{requestId} {
      allow read: if isOwner(resource.data.staffId) || isCNO() || isHR();
      allow create: if isStaff() && request.auth.uid == request.resource.data.staffId;
      allow update: if isCNO() || isHR();
      allow delete: if isOwner(resource.data.staffId) && resource.data.status == 'pending';
    }

    match /swapRequests/{requestId} {
      allow read: if isAuthenticated();
      allow create: if isStaff() && request.auth.uid == request.resource.data.requesterId;
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.targetStaffId || isCNO());
      allow delete: if isOwner(resource.data.requesterId) && resource.data.status == 'pending_target';
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
